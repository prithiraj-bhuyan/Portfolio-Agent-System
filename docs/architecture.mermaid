%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#2E5A88', 'primaryTextColor': '#fff', 'primaryBorderColor': '#1A3A5C', 'lineColor': '#555', 'secondaryColor': '#E8F0FE', 'tertiaryColor': '#F0F4F8' } } }%%

graph TD
    subgraph Layer2["Layer 2: Portfolio Management"]
        PS[/"Portfolio Strategist<br/>Select tickers | Monitor rebalancing"/]
    end

    subgraph Layer1["Layer 1: Stock Analysis Engine (per ticker)"]
        subgraph Analysts["Stage 1: Analyst Team (concurrent)"]
            FA["Fundamental<br/>Analyst"]
            TA["Technical<br/>Analyst"]
            SA["Sentiment<br/>Analyst"]
            NA["News<br/>Analyst"]
        end

        subgraph Research["Stage 2: Researcher Team"]
            BULL["Bullish<br/>Researcher"]
            BEAR["Bearish<br/>Researcher"]
            FAC["Debate<br/>Facilitator"]
        end

        TR["Stage 3: Trader Agent<br/>Propose trade"]
        
        subgraph Risk["Stage 4: Risk Management Team"]
            AGG["Aggressive"]
            NEU["Neutral"]
            CON["Conservative"]
        end

        FM["Stage 5: Fund Manager<br/>Final approval"]
        HG["Stage 6: Human Gate<br/>Approve / Reject"]
        EX["Stage 7: Execute Trade<br/>Update portfolio"]
    end

    subgraph State["Shared State (GlobalState)"]
        GS[("AnalystReports | DebateRecords<br/>TradeProposals | RiskAssessments<br/>FinalDecisions | TransactionLog<br/>InteractionTrace")]
    end

    subgraph Tools["Tool Layer"]
        MDT["MarketData<br/>(yfinance)"]
        TAT["Technical<br/>Indicators"]
        SNT["Sentiment<br/>(Reddit/X)"]
        NWT["News<br/>(NewsAPI)"]
        PAT["Portfolio<br/>Analytics"]
    end

    PS -->|"for each ticker"| FA
    PS -->|"for each ticker"| TA
    PS -->|"for each ticker"| SA
    PS -->|"for each ticker"| NA

    FA --> BULL
    TA --> BULL
    SA --> BULL
    NA --> BULL
    FA --> BEAR
    TA --> BEAR
    SA --> BEAR
    NA --> BEAR

    BULL -->|"2 rounds debate"| FAC
    BEAR -->|"2 rounds debate"| FAC

    FAC --> TR

    TR -->|"if HOLD"| END1(("END"))
    TR -->|"if BUY/SELL"| AGG
    AGG --> NEU --> CON --> FM

    FM -->|"if rejected"| END2(("END"))
    FM -->|"if approved"| HG

    HG -->|"if rejected"| END3(("END"))
    HG -->|"if approved"| EX

    EX --> GS

    FA -.->|read| MDT
    TA -.->|read| MDT
    TA -.->|read| TAT
    SA -.->|read| SNT
    NA -.->|read| NWT
    Risk -.->|read| PAT

    FA -.->|write| GS
    TA -.->|write| GS
    SA -.->|write| GS
    NA -.->|write| GS
    FAC -.->|write| GS
    TR -.->|write| GS
    FM -.->|write| GS

    style Layer2 fill:#E8F0FE,stroke:#2E5A88
    style Layer1 fill:#F0F4F8,stroke:#1A3A5C
    style Analysts fill:#FFF8E1,stroke:#F9A825
    style Research fill:#E8F5E9,stroke:#388E3C
    style Risk fill:#FFEBEE,stroke:#C62828
    style State fill:#F3E5F5,stroke:#7B1FA2
    style Tools fill:#E0F2F1,stroke:#00695C
